*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.env

# ML / indexes
data/hf_cache/
data/profiles/
*.chroma

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# Docker generated (user machine)
# compose dirs live under ~/DockerMCP by default

